 <!DOCTYPE html>
<html lang="hi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ledger Master</title>

<style>
body{
    font-family:Arial,sans-serif;
    background:#f4f4f4;
    padding:20px;
}

.card{
    background:#fff;
    padding:15px;
    border-radius:10px;
    margin-bottom:20px;
    box-shadow:0 0 10px rgba(0,0,0,.1);
}

input,select{
    width:100%;
    padding:10px;
    margin:6px 0;
    box-sizing:border-box;
}

button{
    padding:10px 15px;
    background:#1565c0;
    color:#fff;
    border:none;
    cursor:pointer;
}

table{
    width:100%;
    border-collapse:collapse;
}

th,td{
    border:1px solid #ddd;
    padding:8px;
    text-align:left;
}

th{
    background:#1565c0;
    color:white;
}
</style>
</head>
<body>

<div class="card">

<h2>Create Ledger</h2>

<input
id="ledgerName"
placeholder="Ledger Name">

<select id="groupSelect">
</select>

<input
type="number"
id="openingBalance"
placeholder="Opening Balance">

<select id="balanceType">
<option value="Dr">Dr</option>
<option value="Cr">Cr</option>
</select>

<button onclick="saveLedger()">
Save Ledger
</button>

</div>

<div class="card">

<h2>Ledger List</h2>

<table>

<thead>
<tr>
<th>Name</th>
<th>Group</th>
<th>Opening</th>
<th>Type</th>
</tr>
</thead>

<tbody id="ledgerTable">
</tbody>

</table>

</div>

<script>

let groups =
JSON.parse(
localStorage.getItem("groups")
) || [];

let ledgers =
JSON.parse(
localStorage.getItem("ledgers")
) || [];

function loadGroups(){

let html='';

groups.forEach(g=>{

html += `
<option value="${g.name}">
${g.name}
</option>
`;

});

document.getElementById(
"groupSelect"
).innerHTML = html;

}

function saveLedger(){

let ledgerName =
document.getElementById(
"ledgerName"
).value.trim();

let groupName =
document.getElementById(
"groupSelect"
).value;

let openingBalance =
Number(
document.getElementById(
"openingBalance"
).value
);

let balanceType =
document.getElementById(
"balanceType"
).value;

if(!ledgerName){

alert("Enter Ledger Name");

return;

}

let exists =
ledgers.find(
l =>
l.name.toLowerCase()
===
ledgerName.toLowerCase()
);

if(exists){

alert("Ledger Already Exists");

return;

}

let ledger = {

id:Date.now(),

name:ledgerName,

group:groupName,

opening:openingBalance,

type:balanceType

};

ledgers.push(ledger);

localStorage.setItem(
"ledgers",
JSON.stringify(ledgers)
);

document.getElementById(
"ledgerName"
).value='';

document.getElementById(
"openingBalance"
).value='';

renderLedgers();

alert("Ledger Saved");

}

function renderLedgers(){

let html='';

ledgers.forEach(l=>{

html += `
<tr>
<td>${l.name}</td>
<td>${l.group}</td>
<td>${l.opening}</td>
<td>${l.type}</td>
</tr>
`;

});

document.getElementById(
"ledgerTable"
).innerHTML = html;

}

loadGroups();
renderLedgers();

</script>

</body>
</html>
