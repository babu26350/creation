<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#f4f7fb;
padding:20px;
}

.header{
text-align:center;
padding:40px 20px;
background:linear-gradient(135deg,#0f4c81,#00a8ff);
color:white;
border-radius:15px;
margin-bottom:25px;
}

.header h1{
font-size:32px;
margin-bottom:10px;
}

.header p{
font-size:18px;
}

.packages{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:25px;
max-width:1200px;
margin:auto;
}

.package-card{
background:white;
border-radius:18px;
padding:25px;
box-shadow:0 10px 25px rgba(0,0,0,.08);
transition:.3s;
position:relative;
overflow:hidden;
}

.package-card:hover{
transform:translateY(-8px);
}

.price{
font-size:42px;
font-weight:bold;
color:#0f4c81;
margin:15px 0;
}

.package-title{
font-size:24px;
font-weight:bold;
margin-bottom:10px;
}

.package-card ul{
list-style:none;
margin-top:20px;
}

.package-card ul li{
padding:8px 0;
border-bottom:1px solid #eee;
}

.package-card ul li:last-child{
border-bottom:none;
}

.btn{
display:block;
text-align:center;
background:#0f4c81;
color:white;
text-decoration:none;
padding:12px;
margin-top:20px;
border-radius:10px;
font-weight:bold;
}

.btn:hover{
background:#08345a;
}

.badge{
position:absolute;
top:15px;
right:-35px;
background:#ff9800;
color:white;
padding:8px 40px;
transform:rotate(45deg);
font-size:12px;
font-weight:bold;
}

.contact{
margin-top:40px;
background:white;
padding:25px;
border-radius:15px;
max-width:800px;
margin-left:auto;
margin-right:auto;
box-shadow:0 10px 20px rgba(0,0,0,.08);
text-align:center;
}

.contact h2{
margin-bottom:15px;
color:#0f4c81;
}

.contact a{
display:inline-block;
margin:10px;
padding:12px 20px;
background:#25D366;
color:white;
text-decoration:none;
border-radius:10px;
font-weight:bold;
}

.footer-note{
margin-top:20px;
font-size:14px;
color:#666;
}

</style>

</head>

