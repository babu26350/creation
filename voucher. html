 <!DOCTYPE html>
<html lang="hi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Voucher Entry</title>

<style>

body{
font-family:Arial;
background:#f4f4f4;
margin:0;
}

nav{
background:#1565c0;
padding:12px;
}

nav a{
color:white;
text-decoration:none;
margin-right:15px;
font-weight:bold;
}

.container{
padding:20px;
}

.card{
background:white;
padding:15px;
margin-bottom:20px;
border-radius:10px;
box-shadow:0 0 10px rgba(0,0,0,.1);
}

input,select,textarea{
width:100%;
padding:10px;
margin:6px 0;
box-sizing:border-box;
}

button{
background:#1565c0;
color:white;
border:none;
padding:10px 16px;
cursor:pointer;
}

table{
width:100%;
border-collapse:collapse;
}

th,td{
border:1px solid #ddd;
padding:8px;
}

th{
background:#1565c0;
color:white;
}

</style>
</head>
<body>

<nav>
<a href="groups.html">Groups</a>
<a href="ledger.html">Ledgers</a>
<a href="voucher.html">Vouchers</a>
<a href="inventory.html">Inventory</a>
</nav>

<div class="container">

<div class="card">

<h2>Voucher Entry</h2>

<input
type="date"
id="voucherDate">

<select id="voucherType">

<option>Contra</option>
<option>Payment</option>
<option>Receipt</option>
<option>Journal</option>
<option>Purchase</option>
<option>Sales</option>

</select>

<label>Debit Ledger</label>

<select id="debitLedger"></select>

<label>Credit Ledger</label>

<select id="creditLedger"></select>

<input
type="number"
id="amount"
placeholder="Amount">

<textarea
id="narration"
placeholder="Narration">
</textarea>

<button onclick="saveVoucher()">
Save Voucher
</button>

</div>

<div class="card">

<h2>Voucher Register</h2>

<table>

<thead>
<tr>
<th>Date</th>
<th>Type</th>
<th>Debit</th>
<th>Credit</th>
<th>Amount</th>
</tr>
</thead>

<tbody id="voucherTable">
</tbody>

</table>

</div>

</div>

<script>

document.getElementById("voucherDate").value =
new Date().toISOString().split('T')[0];

let ledgers =
JSON.parse(
localStorage.getItem("ledgers")
) || [];

let vouchers =
JSON.parse(
localStorage.getItem("vouchers")
) || [];

function loadLedgers(){

let html='';

ledgers.forEach(l=>{

html += `
<option value="${l.name}">
${l.name}
</option>
`;

});

document.getElementById(
"debitLedger"
).innerHTML = html;

document.getElementById(
"creditLedger"
).innerHTML = html;

}

function saveVoucher(){

let voucher = {

id:Date.now(),

date:
document.getElementById(
"voucherDate"
).value,

type:
document.getElementById(
"voucherType"
).value,

debitLedger:
document.getElementById(
"debitLedger"
).value,

creditLedger:
document.getElementById(
"creditLedger"
).value,

amount:Number(
document.getElementById(
"amount"
).value
),

narration:
document.getElementById(
"narration"
).value

};

if(voucher.amount<=0){

alert("Amount Required");

return;

}

vouchers.push(voucher);

localStorage.setItem(
"vouchers",
JSON.stringify(vouchers)
);

document.getElementById(
"amount"
).value='';

document.getElementById(
"narration"
).value='';

renderVouchers();

alert("Voucher Saved");

}

function renderVouchers(){

let html='';

vouchers.forEach(v=>{

html += `
<tr>

<td>${v.date}</td>

<td>${v.type}</td>

<td>${v.debitLedger}</td>

<td>${v.creditLedger}</td>

<td>${v.amount}</td>

</tr>
`;

});

document.getElementById(
"voucherTable"
).innerHTML = html;

}

loadLedgers();

renderVouchers();

</script>

</body>
</html>
